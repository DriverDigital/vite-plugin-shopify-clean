{
  "name": "@driver-digital/vite-plugin-shopify-clean",
  "version": "1.1.2",
  "type": "module",
  "description": "Vite plugin for correctly cleaning up an assets folder",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vite",
    "shopify",
    "vite-plugin"
  ],
  "author": "Driver Digital",
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "npm run build -- --watch",
    "build": "tsup src/index.ts --dts --format cjs,esm --target node20 --clean",
    "watch": "tsup src/index.ts --dts --format cjs,esm --target node20 --clean --watch",
    "lint": "eslint src --ext .ts,.js --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify-package": "node scripts/verify-package.mjs",
    "test:sandbox": "bash scripts/test-integration.sh"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.0.18"
  }
}
